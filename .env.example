# -*- coding: utf-8 -*-
# 量化金融数据采集系统 - 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ===========================
# TDengine 数据库配置
# ===========================
TDENGINE_HOST=tdengine
TDENGINE_PORT=6030
TDENGINE_REST_PORT=6041
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=quant_db

# ===========================
# 数据源配置
# ===========================
# pytdx 通达信服务器地址（多个地址用逗号分隔）
PYTDX_HOSTS=60.12.136.250,218.75.126.9,115.238.56.198,60.191.117.167,180.153.18.170,115.238.90.165
PYTDX_PORT=7709

# QMT 迅投配置
QMT_PATH=/data/qmt
QMT_HOST=127.0.0.1
QMT_PORT=18080

# modtdx 配置（如需使用）
MODTDX_ENABLED=false

# ===========================
# 采集配置
# ===========================
# 采集间隔（秒）
COLLECT_INTERVAL=30
# 最大重试次数
MAX_RETRY=3
# 批量写入大小
BATCH_SIZE=1000
# 缓存队列大小
CACHE_SIZE=10000
# 采集超时时间（秒）
COLLECT_TIMEOUT=30

# ===========================
# JWT认证配置
# ===========================
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===========================
# Redis缓存配置
# ===========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================
# API配置
# ===========================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=*

# ===========================
# 日志配置
# ===========================
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# ===========================
# 数据类型配置
# ===========================
# 支持的数据类型（逗号分隔）
DATA_TYPES=stock,futures,index,sector
# K线周期（逗号分隔）
KL_INTERVALS=1min,5min,15min,30min,60min,1day,1week,1month

# ===========================
# 时区配置
# ===========================
TZ=Asia/Shanghai
